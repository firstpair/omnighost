// ============================================================================
// CHANGE 22 (main.ts + src/modals/link-to-ghost-modal.ts) — make the remaining
// per-URL / per-note operations multi-blog aware (same 401 / wrong-blog class as
// CHANGE 21).
//
// LinkToGhostModal: constructor takes `plugin`; handleLink resolves the blog from
//   the pasted URL (plugin.blogForUrl), fetches with that blog's client, rebuilds
//   the URL from that blog's address, and passes `blog` out in the onLink payload.
// openLinkToGhostModal: relaxed guard (any blog OR global key), passes plugin,
//   forwards `blog` to linkNoteToGhostPost.
// linkNoteToGhostPost(post, file, source, ghostUrl, blog?): tags g_blog with the
//   blog's domain key (both source branches) and moves the note into that blog's
//   folder via the new ensureInFolder(file, folderPath); ensureInSyncFolder now
//   delegates to it.
//
// seedActiveNoteFromGhost: was seeding against the engine's default-blog client.
//   Now resolves the note's target blog (resolveBlogsForFile[0]), setActiveBlog
//   to it before seedNoteFromGhostBySlug, and restoreDefaultBlogContext in a
//   finally. Guard checks that blog's key instead of the global key.
//
// scheduleCurrentNote: fetched recent posts via the global client to compute the
//   next slot. Now uses the note's target blog's client (getClientForBlog).
//
// LEFT AS-IS (intentionally global, not wrong-blog bugs): testGhostConnection
//   (legacy global connection test; per-blog "Test" buttons exist in settings)
//   and CalendarView.loadPostsForMonth (shows the global/default blog's posts —
//   a multi-blog calendar would be a larger feature change).
//
// New/changed helpers:

/** Move a file into `folderPath` if not already there; returns moved TFile or null. */
async ensureInFolder(file: TFile, folderPath: string): Promise<TFile | null> {
  const dest = normalizePath(folderPath);
  const currentFolder = file.parent?.path ?? '';
  if (currentFolder === dest) return null;
  if (!this.app.vault.getAbstractFileByPath(dest)) await this.app.vault.createFolder(dest);
  const newPath = normalizePath(`${dest}/${file.name}`);
  await this.app.fileManager.renameFile(file, newPath);
  return this.app.vault.getFileByPath(newPath);
}
async ensureInSyncFolder(file: TFile): Promise<TFile | null> {
  return this.ensureInFolder(file, this.settings.syncFolder);
}

// modal handleLink (key lines):
//   const blog = this.plugin ? this.plugin.blogForUrl(this.ghostUrlInput) : null;
//   const client = blog ? this.plugin.getClientForBlog(blog) : this.ghostClient;
//   const ghostUrl = buildGhostEditorUrl(blog ? blog.url : this.settings.ghostUrl, postId);
//   const post = await client.getPost(postId);
//   await this.onLink({ ghostPost: post, obsidianFile, source: this.source, ghostUrl, blog });
//
// linkNoteToGhostPost: source==='ghost' adds ghostFields.blog = blogPropertyYaml([blog])
//   when blog; source==='obsidian' upserts g_blog = blogPropertyYaml([blog]); both
//   call ensureInFolder(file, blog ? blog.folder : this.settings.syncFolder).


// ============================================================================
// CHANGE 23 (main.ts + src/types.ts) — renaming a blog orphaned references, and
// normalize silently DROPPED unmatched g_blog tokens (data loss).
//
// REPRO: note's g_blog held the old display name "Chief Scientist". User renamed
// the blog to "chief.sc" in settings, then ran normalize. "Chief Scientist" no
// longer matched the blog (neither domain "chief.sc" nor current name), so
// normalize discarded it — chief vanished from g_blog entirely.
//
// FIXES:
// 1. normalize no longer drops tokens. It maps each token to a blog's domain key
//    when it matches, and KEEPS the original token verbatim when it doesn't, so
//    nothing is ever silently removed. (Suffix-key migration also now covers the
//    name suffix AND every alias suffix -> domain suffix.)
// 2. GhostBlog gains `aliases?: string[]` — prior names/domains. blogMatchesToken
//    matches current domain, current name, OR any alias, so a note holding an old
//    identifier still resolves after a rename.
// 3. Renaming a blog (Name field blur) records the prior name as an alias and runs
//    migrateBlogRename(oldName, blog): across blog-folder notes it rewrites g_blog
//    tokens equal to the old name into the new domain key, and moves per-blog
//    id/url keys from the old name's suffix to the new domain suffix. So a rename
//    now repairs existing notes instead of orphaning them, in any order.
//
// src/types.ts — GhostBlog:
//   aliases?: string[]; // lowercased prior names/domains, for back-compat matching
//
// blogMatchesToken — alias-aware:
//   blogMatchesToken(blog, token) {
//     const t = token.trim().toLowerCase();
//     if (t === this.blogDomainKey(blog) || t === blog.name.trim().toLowerCase()) return true;
//     return Array.isArray(blog.aliases) && blog.aliases.includes(t);
//   }
//
// normalize g_blog loop — keep unmatched tokens:
//   for (const t of tokens) {
//     const b = this.settings.blogs.find(bl => this.blogMatchesToken(bl, t));
//     const key = b ? this.blogDomainKey(b) : t;          // <-- keep verbatim if unknown
//     const lk = key.toLowerCase();
//     if (!seen.has(lk)) { seen.add(lk); out.push(key); }
//   }
//   // suffix migration now iterates Set([blogKeySuffix(name), ...aliases.map(blogKeySuffix)]) minus domSuffix
//
// renderBlogsSettings Name field — record alias + migrate on blur:
//   addText(t => {
//     let originalName = blog.name;
//     t.setValue(blog.name).onChange(async v => { blog.name = v.trim(); await plugin.saveSettings(); });
//     t.inputEl.addEventListener('blur', async () => {
//       const prev = originalName;
//       if (blog.name && prev && blog.name !== prev) {
//         originalName = blog.name;
//         blog.aliases = blog.aliases || [];
//         const lp = prev.trim().toLowerCase();
//         if (lp && lp !== blog.name.trim().toLowerCase() && !blog.aliases.includes(lp)) blog.aliases.push(lp);
//         await plugin.saveSettings();
//         await plugin.migrateBlogRename(prev, blog);
//       }
//     });
//   });

async migrateBlogRename(oldName: string, blog: GhostBlog): Promise<void> {
  const prefix = this.settings.yamlPrefix;
  const oldTok = oldName.trim().toLowerCase();
  const oldSuffix = this.blogKeySuffix(oldName);
  const newKey = this.blogDomainKey(blog);
  const newSuffix = this.blogKeyFor(blog);
  if (!oldTok) return;
  const files = this.app.vault.getMarkdownFiles().filter(f => this.fileInAnyBlogFolder(f));
  let changed = 0;
  for (const file of files) {
    try {
      const before = await this.app.vault.read(file);
      const split = splitFrontmatter(before); if (!split) continue;
      let fmObj: any; try { fmObj = parseYaml(split.raw) || {}; } catch { continue; }
      if (!fmObj || typeof fmObj !== 'object') continue;
      const updates: Record<string, string> = {}; const removals: string[] = [];
      const raw = fmObj[`${prefix}blog`];
      const tokens = Array.isArray(raw) ? raw.map((v: any) => String(v).trim()).filter(Boolean)
                   : (typeof raw === 'string' && raw.trim() ? [raw.trim()] : []);
      if (tokens.some((t: string) => t.toLowerCase() === oldTok)) {
        const seen = new Set<string>(); const out: string[] = [];
        for (const t of tokens) {
          const k = t.toLowerCase() === oldTok ? newKey : t;
          const lk = k.toLowerCase();
          if (!seen.has(lk)) { seen.add(lk); out.push(k); }
        }
        updates[`${prefix}blog`] = `[${out.map(k => `"${k}"`).join(', ')}]`;
      }
      if (oldSuffix !== newSuffix) {
        for (const base of ['id', 'public_url']) {
          const oldKey = `${prefix}${base}_${oldSuffix}`, newK = `${prefix}${base}_${newSuffix}`;
          const val = fmObj[oldKey];
          if (newK in fmObj) { if (oldKey in fmObj) removals.push(oldKey); }
          else if (typeof val === 'string' && val) { updates[newK] = val; removals.push(oldKey); }
        }
      }
      if (!Object.keys(updates).length && !removals.length) continue;
      let content = before;
      if (Object.keys(updates).length) content = upsertFrontmatterKeys(content, updates);
      if (removals.length) content = removeFrontmatterKeys(content, removals);
      if (content !== before) { await this.app.vault.modify(file, content); changed++; }
    } catch (e) { console.error('[Ghost] rename migration failed for', file.path, e); }
  }
  if (changed) new Notice(`Updated ${changed} note${changed === 1 ? '' : 's'} for renamed blog "${blog.name}"`);
}


// ============================================================================
// CHANGE 24 (main.ts + src/sync/sync-engine.ts) — orphan "Keep in both" hijacked
// the clean g_url/g_public_url, producing two URLs for one blog and none for the
// other.
//
// CAUSE: keepOrphanInBoth synced ONLY the orphan blog — syncFileToBlogs(file,
// [blog]) — which is a single-blog (writeBack) sync. In writeBack mode the engine
// rewrites the clean keys g_url/g_public_url. The orphan blog (chief) was not the
// blog that owns those clean keys (collected owns them; g_id is collected's), so
// chief overwrote g_url/g_public_url with its own values while ALSO having its
// per-blog g_public_url_chief_sc — hence two chief URLs and collected's clean
// public_url clobbered.
//
// FIX 1 (main.ts keepOrphanInBoth): sync the FULL union, not just the orphan:
//     await this.syncFileToBlogs(file, all);   // was: [blog]
//   With 2+ blogs this runs multi-blog (writeBack=false): each blog uses its own
//   per-blog keys and the legacy owner keeps the clean keys — no hijack.
//
// FIX 2 (sync-engine.ts, defense in depth): in writeBack mode only rewrite the
//   clean keys when they actually belong to the post being synced:
//     const ownsClean = !resolvedGhostId || resolvedGhostId === targetId;
//     if (this.writeBack && ownsClean && (needsId || needsUrl || needsPublic)) { ... }
//   So a single-blog sync of a non-owning blog (e.g. selecting only the other blog
//   in the edit modal) can no longer clobber clean keys that point at a different
//   post.
//
// MANUAL REPAIR for the already-corrupted note: g_id is still collected's, so
// restore the two clean keys to collected and chief keeps its suffix keys:
//   g_url        -> https://collected.ga/ghost/#/editor/post/<g_id>
//   g_public_url -> https://collected.ga/pessoa/
// leaving g_id_chief_sc / g_public_url_chief_sc as chief's. (One URL per blog.)


// ============================================================================
// CHANGE 25 (main.ts + src/sync/sync-engine.ts) — CLEAN-KEY ELIMINATION /
// "all blogs equal". The note is primary; every target blog is just a
// destination. The shared g_id / g_url / g_public_url and the "which blog owns
// them" concept are gone. EVERY blog (single or multi) gets its own keys:
//     g_id_<domain>          post id on that blog
//     g_url_<domain>         editor (admin) URL on that blog
//     g_public_url_<domain>  published URL on that blog
// Shared, note-level keys remain: g_slug, g_published, g_published_at,
// g_post_access, g_featured, g_cover_from_first_image, g_excerpt,
// g_feature_image, g_tags, g_no_sync, g_blog.
//
// No migration. New imports/syncs produce the new shape; any lingering clean
// g_id/g_url/g_public_url are ignored on read and stripped on the next sync.
//
// NEW HELPERS (main.ts):
//   blogKeys(blog)            -> { id, url, pub } domain-suffixed key names (for WRITES)
//   blogReadSuffixes(blog)    -> [domain, name, ...aliases] suffixes (for READS)
//   readBlogId(fmObj, blog)   -> id from g_id_<suffix> (domain/name/alias) or old g_ids map
//   readBlogPublicUrl(fmObj, blog) -> public url, same fallback order
//   allBlogKeyNames(blog)     -> every id/url/public_url key name across read suffixes
//
// REWRITTEN:
//   syncFileToBlogs           - writeBack ALWAYS false; per blog: knownId=readBlogId,
//                               then write blogKeys.id/url/pub; write shared g_slug once;
//                               purge name/alias-suffix variants AND any leftover clean
//                               g_id/g_url/g_public_url and old g_ids/g_public_urls maps.
//   buildBlogStatuses         - per-blog public url via readBlogPublicUrl, for ALL targets
//                               (was: only when 2+ blogs, with legacy owner fallback).
//   resolveGhostJobs          - readBlogId only; no legacy clean id.
//   storedKeysForBlog         - { keys: allBlogKeyNames(blog), url: readBlogPublicUrl(...) }.
//   restoreDefaultBlogContext - setActiveBlog(..., false).
//   importPostAsNote          - writes shared g_slug + blogKeys.id/url/pub (was clean keys).
//   writePostAsNoteInFolder   - now takes the blog OBJECT; writes per-blog keys + shared slug.
//   importAllFromBlog         - passes the blog object (was blogDomainKey string).
//   linkNoteToGhostPost       - ghost-source: ghostFields use id_<s>/url_<s>/public_url_<s>
//                               (+ shared slug); obsidian-source: upsert per-blog id/url +
//                               g_blog + shared slug, then route. No clean-key writers.
//   seedActiveNoteFromGhost   - "already linked?" now checks readBlogId(blog); writeBack false.
//   CalendarView.buildVaultIndex - indexes EVERY g_id_* (and legacy g_id) value -> note,
//                               so post<->note matching works without clean keys.
//   sync-engine.seedNoteFromGhostBySlug - computes blogSlug from activeBaseUrl host and
//                               writes id_<blogSlug>/url_<blogSlug>/public_url_<blogSlug>
//                               (+ shared slug) via upsertGhostMetadata; no clean keys.
//
// DEAD CODE (left in place, never reached because writeBack is always false now):
//   sync-engine writeBack blocks that called updateFrontmatterWithGhostId/Url, and the
//   old SyncEngine.deletePostForFile (the live delete path uses resolveGhostJobs /
//   deleteOneRemote). In the .ts source these can simply be deleted.
//
// src/types.ts — GhostBlog no longer needs any clean-key handling; aliases?: string[]
// (added in CHANGE 23) is the only per-blog identity state.
//
// RESULT for a note published to both blogs (the shape to re-import into):
//   g_blog: [collected.ga, chief.sc]
//   g_slug: pessoa
//   g_id_collected_ga / g_url_collected_ga / g_public_url_collected_ga
//   g_id_chief_sc      / g_url_chief_sc      / g_public_url_chief_sc
//   (no g_id, no g_url, no g_public_url)
